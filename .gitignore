# ==========================================================
# TMM — repository .gitignore (applies to the whole repo)
# ==========================================================

# ----- Dependencies -----
node_modules/
**/node_modules/

# ----- Environment / secrets (NEVER commit) -----
# Ignore every .env variant anywhere, but keep the *.example templates.
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example

# ----- Build output -----
dist/
dist-ssr/
build/
**/dist/
**/build/
*.local

# ----- Deploy / platform -----
.vercel

# ----- Logs -----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ----- Test & tooling artifacts -----
test-results/
playwright-report/
coverage/
tests/validation/artifacts/*
!tests/validation/artifacts/.gitkeep
tests/validation/.auth/

# ----- Cursor local debug logs (rules/config stay tracked) -----
.cursor/*.log

# ----- OS / editor cruft -----
.DS_Store
Thumbs.db
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ----- Large local reference backup (old pre-migration project, not part of the app) -----
Reference - TMM Before Vite-React-Tailwind Migration/
