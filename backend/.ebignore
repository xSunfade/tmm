# Elastic Beanstalk ignore file
# Files and directories to exclude from deployment

# Environment files (secrets)
.env
.env.local
.env.*.local

# Dependencies (will be installed on server)
node_modules/

# Database files (will be created on server)
*.db
*.db-shm
*.db-wal

# Development files
.git/
.gitignore
*.log
.DS_Store

# Documentation (optional, can include if desired)
# README.md
# SETUP_INSTRUCTIONS.md
# AWS_DEPLOYMENT.md

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Test files
test/
tests/
*.test.js
*.spec.js

