# ==========================================================
# Root .env — local test/dev helpers (copy to .env, fill in)
# Do NOT commit the real .env. Values below are placeholders.
# ==========================================================

# Supabase JWT for an authenticated test user (used by local validation scripts).
# Obtain via: npm run test:stripe:get-jwt (or your own auth flow).
TMM_PLUS_JWT=

# Plaid/test identifiers used by local validation scripts.
TEST_ITEM_ID=
TEST_ACCOUNT_ID=
OTHER_USERS_ACCOUNT_ID=

# Local backend URL.
BACKEND_URL=http://localhost:3000
