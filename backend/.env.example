# ============================================
# TMM Plaid Backend - Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control
#
# Usage:
#   1. Copy: cp .env.example .env
#   2. Edit .env with your actual credentials
#   3. For production, set these in your hosting platform's environment variables
# ============================================

# --------------------------------------------
# Server Configuration
# --------------------------------------------
# Port for the backend API server
PORT=3000

# Node environment: 'development' or 'production'
# In development, .env file is loaded automatically
# In production, use hosting platform environment variables
NODE_ENV=development

# --------------------------------------------
# Plaid API Configuration
# --------------------------------------------
# Get these from: https://dashboard.plaid.com/developers/keys
# Required for all Plaid features

# Your Plaid Client ID
PLAID_CLIENT_ID=your_plaid_client_id_here

# Your Plaid Secret Key
# ??  KEEP THIS SECRET - Never commit to version control
PLAID_SECRET=your_plaid_secret_here

# Plaid Environment: 'sandbox', 'development', or 'production'
# - sandbox: For testing (default)
# - development: For development with test institutions
# - production: For live production use
PLAID_ENVIRONMENT=sandbox

# Optional: Plaid webhook URL for link token (e.g. https://your-api.com/api/webhooks/plaid)
# When set, Plaid will send item/transaction events to this URL. Omit in dev if not using webhooks.
PLAID_WEBHOOK_URL=

# Optional: scheduled /transactions/sync interval in minutes
# Default is 1440 (daily). Set to 0 to disable scheduler.
PLAID_TRANSACTIONS_SYNC_INTERVAL_MINUTES=1440

# Optional: scheduled history archive interval in minutes
# Default is 10080 (weekly). Set to 0 to disable scheduler.
HISTORY_SNAPSHOT_INTERVAL_MINUTES=10080

# Optional: no-op window for archive writes. If >0, archive skips rewriting
# snapshots when an equivalent net_worth_points row was updated recently.
# Keep 0 to disable this optimization.
HISTORY_ARCHIVE_NOOP_WINDOW_MINUTES=0

# Optional: rate limits for writing per-alt TMM net-worth history points.
HISTORY_TMM_WRITE_USER_HOURLY_MAX=12
HISTORY_TMM_WRITE_GLOBAL_HOURLY_MAX=10000

# Optional: global quota identity for TMM history writes.
# If unset, global quota is skipped and only per-user quota is enforced.
HISTORY_TMM_WRITE_GLOBAL_USER_ID=

# Optional: rolling backfill window used after /transactions/sync
PLAID_TRANSACTIONS_BACKFILL_DAYS=10

# Max active Plaid Items allowed per user (user-visible hard cap)
PLAID_ITEM_CAP=5

# Internal safety ceiling to protect against logic/race bugs
PLAID_ITEM_SAFETY_CEILING=10

# Connection Stability Policy: max NEW connections in rolling 7 days
PLAID_NEW_CONNECTIONS_PER_7_DAYS=2

# --------------------------------------------
# Supabase Configuration
# --------------------------------------------
# Get these from: Supabase Dashboard > Settings > API
# Opt in to new API keys in your Supabase project settings
# Required for database storage

# Your Supabase Project URL
# Example: https://your-project.supabase.co
SUPABASE_URL=https://your-project.supabase.co

# Your Supabase Publishable Key (replaces deprecated anon key)
# This is safe to use client-side (respects RLS policies)
# New keys start with 'sb_publishable_' prefix
# Get this from: Supabase Dashboard > Settings > API > Publishable key
SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# Your Supabase Secret Key (replaces deprecated service_role key)
# ??  KEEP THIS SECRET - Never commit to version control
# This bypasses RLS and should only be used server-side
# Secret keys are hidden by default - click "reveal" in Supabase dashboard
# New keys start with 'sb_secret_' prefix
# Cannot be used in browsers (will fail with HTTP 401)
# Get this from: Supabase Dashboard > Settings > API > Secret key (click "reveal")
SUPABASE_SECRET_KEY=your-secret-key-here

# --------------------------------------------
# Google OAuth (Google Sheets export/import integration)
# --------------------------------------------
# Get these from: Google Cloud Console > APIs & Services > Credentials
# Only required if the Google Sheets backup/export feature is enabled.
# Consumed by backend/config.js (config.google.*).

# OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=

# OAuth 2.0 Client Secret
# ⚠️  KEEP THIS SECRET - Never commit to version control
GOOGLE_CLIENT_SECRET=

# Backend callback URL Google redirects to after consent
# Example: http://localhost:3000/api/google/oauth/callback (dev) or https://api.tmm.finance/... (prod)
GOOGLE_OAUTH_REDIRECT_URI=

# Frontend URL the backend bounces the user back to after token exchange
GOOGLE_OAUTH_FRONTEND_REDIRECT=

# Optional: override the requested OAuth scopes (space-delimited).
# Default (set in config.js): spreadsheets + userinfo.email + drive.file
GOOGLE_OAUTH_SCOPES=

# --------------------------------------------
# Stripe Configuration
# --------------------------------------------
# Required for account upgrade + subscription management

# Stripe Secret Key (server-side only)
# ??  KEEP THIS SECRET - Never commit to version control
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Stripe Webhook Signing Secret for /api/webhooks/stripe
# ??  KEEP THIS SECRET - Never commit to version control
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# Stripe Price ID for the TMM+ recurring subscription
# Example: price_1234567890abcdef
STRIPE_PRICE_ID_TMM_PLUS=price_your_tmm_plus_price_id_here

# --------------------------------------------
# CORS Configuration
# --------------------------------------------
# Allowed origin for CORS requests
# In development, localhost:5500 and 127.0.0.1:5500 are automatically allowed
# In production, set this to your frontend domain (e.g., https://yourdomain.com)
CORS_ORIGIN=http://localhost:5500

# Optional (dev only): allow unlisted origins for local troubleshooting.
# Keep false/unset in production.
ALLOW_DEV_UNLISTED_CORS=false

# --------------------------------------------
# Security Configuration
# --------------------------------------------
# Encryption key for storing access tokens at rest
# If not set, a key will be generated (not recommended for production)
# Generate a secure key: openssl rand -hex 32
# ??  KEEP THIS SECRET - Never commit to version control
TOKEN_ENCRYPTION_KEY=

# TLS (development only)
# If Google OAuth or Plaid fail with "fetch failed" / UNABLE_TO_VERIFY_LEAF_SIGNATURE
# (common with antivirus SSL inspection on Windows), set this to true locally.
# Prefer NODE_EXTRA_CA_CERTS with your corporate/AV root CA when possible.
# TLS_INSECURE_SKIP_VERIFY=true

# Request hardening
REQUEST_TIMEOUT_MS=30000
JSON_BODY_LIMIT=256kb
ENABLE_HSTS=false

# Baseline rate limits (requests per minute)
API_RATE_LIMIT_MAX=240
PLAID_WEBHOOK_RATE_LIMIT_MAX=180
PLAID_CREATE_LINK_RATE_LIMIT_MAX=40
PLAID_EXCHANGE_RATE_LIMIT_MAX=30
PLAID_SYNC_RATE_LIMIT_MAX=16

# ============================================
# Production Deployment Notes
# ============================================
# For Vercel/Render/Fly.io/Railway:
#   1. Set all variables in your hosting platform's environment variables dashboard
#   2. Set NODE_ENV=production
#   3. Set CORS_ORIGIN to your frontend domain
#   4. Ensure SUPABASE_SECRET_KEY is set securely (never expose in client-side code)
#   5. Set TOKEN_ENCRYPTION_KEY for production (generate with: openssl rand -hex 32)
#
# New Supabase API Keys Benefits:
#   - Zero-downtime rotation
#   - Instant revocation
#   - Better security practices
#   - Audit logging for secret key reveals
#
# See SUPABASE_SETUP.md for complete setup instructions
# ============================================
